    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: spend-by-cycle\n",
        "#| code-summary: Total paid media spend by cycle\n",
        "#| fig-cap: Paid media disbursements by election cycle. TV holds the top spot in all three cycles despite a decade of digital growth headlines.\n",
        "\n",
        "## filter to paid media for a cleaner story\n",
        "paid_media = ['TV/Broadcast', 'Digital', 'Direct Mail']\n",
        "plot_data = channel_by_cycle[channel_by_cycle['category'].isin(paid_media)].copy()\n",
        "\n",
        "## share of paid media within each cycle, the slope chart uses this too\n",
        "totals = plot_data.groupby('cycle')['total_spend'].transform('sum')\n",
        "plot_data['share'] = plot_data['total_spend'] / totals * 100\n",
        "\n",
        "cycles = sorted(plot_data['cycle'].unique())\n",
        "x = np.arange(len(cycles))\n",
        "width = 0.27\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8, 4.6))\n",
        "\n",
        "for i, cat in enumerate(paid_media):\n",
        "    vals = (plot_data[plot_data['category'] == cat]\n",
        "            .set_index('cycle').reindex(cycles)['total_spend'])\n",
        "    bars = ax.bar(x + (i - 1) * width, vals / 1e6, width,\n",
        "                  label=cat, color=colors[cat])\n",
        "    ## dollar label on every bar\n",
        "    for rect, v in zip(bars, vals):\n",
        "        ax.text(rect.get_x() + rect.get_width() / 2, rect.get_height() + 45,\n",
        "                fmt_dollars(v), ha='center', fontsize=9.5,\n",
        "                fontweight='bold', color=colors[cat])\n",
        "\n",
        "ax.set_xticks(x)\n",
        "ax.set_xticklabels([f\"{c}\\n{'midterm' if c % 4 else 'presidential'}\" for c in cycles])\n",
        "\n",
        "### labels carry the values, so the whole y axis can go\n",
        "ax.yaxis.set_visible(False)\n",
        "ax.spines['left'].set_visible(False)\n",
        "ax.margins(y=0.12)\n",
        "\n",
        "ax.legend(fontsize=9, loc='upper right', frameon=False, ncol=1)\n",
        "\n",
        "headline(ax, 'TV is still the biggest line item, every cycle',\n",
        "         'total paid media disbursements by election cycle, FEC operating expenditures')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "spend-by-cycle",
      "execution_count": null,
      "outputs": []
    },
