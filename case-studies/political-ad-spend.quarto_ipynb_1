    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: channel-mix-slope\n",
        "#| code-summary: Channel mix shift across cycles, slope chart\n",
        "#| fig-cap: Channel share of paid media across cycles. Direct mail nearly doubles its share in the midterm, then gives most of it back in 2024.\n",
        "\n",
        "mix = plot_data.pivot(index='cycle', columns='category', values='share')[paid_media]\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8, 4.6))\n",
        "\n",
        "## soft band behind the midterm column, that's where the action is\n",
        "ax.axvspan(2021.7, 2022.3, color='#f1f5f9', zorder=0)\n",
        "\n",
        "## value labels go above the line for TV and digital, below for mail,\n",
        "## otherwise the 2022 numbers pile up on each other\n",
        "offset = {'TV/Broadcast': 2.2, 'Digital': 2.2, 'Direct Mail': -3.6}\n",
        "\n",
        "for cat in paid_media:\n",
        "    ax.plot(mix.index, mix[cat], marker='o', markersize=7, linewidth=2.5,\n",
        "            color=colors[cat], markerfacecolor='white', markeredgewidth=2.5)\n",
        "    for cyc in mix.index:\n",
        "        v = mix.loc[cyc, cat]\n",
        "        ax.text(cyc, v + offset[cat], f'{v:.0f}%', ha='center',\n",
        "                fontsize=10, fontweight='bold', color=colors[cat])\n",
        "    ## channel name rides at the end of its own line, no legend needed\n",
        "    ax.text(2024.25, mix.loc[2024, cat], cat, va='center',\n",
        "            fontsize=10, fontweight='bold', color=colors[cat])\n",
        "\n",
        "ax.set_xticks([2020, 2022, 2024])\n",
        "ax.set_xlim(2019.5, 2025.9)\n",
        "ax.set_ylim(5, 56)\n",
        "ax.yaxis.set_visible(False)\n",
        "ax.spines['left'].set_visible(False)\n",
        "\n",
        "headline(ax, 'Midterm money moves to the mailbox',\n",
        "         'channel share of paid media spend by cycle')\n",
        "\n",
        "plt.tight_layout()\n",
