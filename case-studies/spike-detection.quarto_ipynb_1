   "source": [
    "#| label: detection-algorithm\n",
    "#| code-summary: 'Robust tiered spike detection: rolling median + MAD'\n",
    "\n",
    "### tuned on this dataset: z>5 alone flagged too much (daily wiki traffic is\n",
    "### heavy tailed), z>5 with 2-day persistence missed the 1-day planted spike.\n",
    "### two tiers handle both shapes.\n",
    "WINDOW_DAYS = 21      ## 3 weeks of trailing history for the baseline\n",
    "Z_PERSISTENT = 5.0    ## threshold for the persistent tier\n",
    "Z_EXTREME = 12.0      ## a single day this far out counts on its own\n",
    "MIN_PERSIST = 2       ## consecutive days required in the persistent tier\n",
    "\n",
    "def detect_spikes_for_article(grp):\n",
    "    \"\"\"robust two-tier spike detection for one article's daily series\"\"\"\n",
    "    grp = grp.sort_values('timestamp').reset_index(drop=True)\n",
    "\n",
    "    ## rolling robust baseline\n",
    "    grp['rolling_median'] = grp['views'].rolling(WINDOW_DAYS, min_periods=7).median()\n",
    "    grp['rolling_mad'] = (\n",
    "        grp['views'].rolling(WINDOW_DAYS, min_periods=7)\n",
    "        .apply(lambda x: np.median(np.abs(x - np.median(x))), raw=True)\n",
    "    )\n",
    "    ### scale MAD so it's comparable to a std dev under normality\n",
    "    grp['rolling_sigma'] = grp['rolling_mad'] * 1.4826\n",
    "\n",
    "    ## z-score against the robust baseline\n",
    "    grp['robust_z'] = (\n",
    "        (grp['views'] - grp['rolling_median'])\n",
    "        / grp['rolling_sigma'].replace(0, np.nan)\n",
    "    )\n",
    "\n",
    "    ## tier 1: persistent. find runs of consecutive days above Z_PERSISTENT\n",
    "    ## and keep whole runs that last at least MIN_PERSIST days\n",
    "    grp['above'] = grp['robust_z'] > Z_PERSISTENT\n",
    "    run_id = (~grp['above']).cumsum()\n",
    "    run_len = grp.groupby(run_id)['above'].transform('sum')\n",
    "    grp['persistent'] = grp['above'] & (run_len >= MIN_PERSIST)\n",
    "\n",
    "    ## tier 2: extreme. one day this far above baseline stands on its own\n",
    "    grp['extreme'] = grp['robust_z'] > Z_EXTREME\n",
    "\n",
    "    grp['is_spike'] = grp['persistent'] | grp['extreme']\n",
    "    return grp\n",
    "\n",
    "## manual loop instead of groupby().apply(), reads cleaner and dodges the\n",
    "## include_groups deprecation dance in pandas 2.2+\n",
    "per_article = []\n",
    "for article_name, grp in df.groupby('article'):\n",
    "    res = detect_spikes_for_article(grp.copy())\n",
    "    res['article'] = article_name\n",
    "    per_article.append(res)\n",
    "results = pd.concat(per_article, ignore_index=True)\n",
    "\n",
    "## group consecutive flagged days into distinct events, then rank.\n",
    "## an alert list is only useful if it's ranked\n",
    "flagged = results[results['is_spike']].copy()\n",
    "flagged['gap'] = flagged.groupby('article')['timestamp'].diff().dt.days.fillna(99)\n",
    "flagged['event_id'] = (flagged['gap'] > 1).groupby(flagged['article']).cumsum()\n",
    "\n",
    "events = (\n",
    "    flagged.groupby(['article', 'event_id'])\n",
    "    .agg(\n",
    "        start=('timestamp', 'min'),\n",
    "        n_days=('is_spike', 'sum'),\n",
    "        peak_z=('robust_z', 'max'),\n",
    "        peak_views=('views', 'max'),\n",
    "        baseline=('rolling_median', 'median'),\n",
    "    )\n",
    "    .reset_index()\n",
    "    .sort_values('peak_z', ascending=False)\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "events['lift'] = (events['peak_views'] / events['baseline']).round(1)\n",
    "\n",
    "## peak date per event, the charts use this\n",
    "peak_dates = []\n",
    "for _, r in events.iterrows():\n",
    "    sub = flagged[(flagged['article'] == r['article']) & (flagged['event_id'] == r['event_id'])]\n",
    "    peak_dates.append(sub.loc[sub['robust_z'].idxmax(), 'timestamp'])\n",
    "events['peak_date'] = peak_dates\n",
    "\n",
    "n_events = len(events)\n",
    "n_flagged_articles = events['article'].nunique()\n",
    "print(f\"{n_events} distinct events across {n_flagged_articles} of {n_articles} articles\")\n",
    "print(f\"\\ntop 12 events by peak robust z:\")\n",
    "show = events.head(12).copy()\n",
    "show['start'] = show['start'].dt.date\n",
    "show['peak_z'] = show['peak_z'].round(1)\n",
    "print(show[['article', 'start', 'n_days', 'peak_z', 'lift']].to_string(index=False))"
   ]
