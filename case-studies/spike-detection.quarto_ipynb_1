    "#| label: load-wiki-data\n",
    "#| code-summary: Load real Wikipedia pageviews from the Parquet cache\n",
    "\n",
    "import json\n",
    "import time\n",
    "from pathlib import Path\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import polars as pl\n",
    "\n",
    "CACHE = Path(\"../data/cache/wikipedia\")\n",
    "if not CACHE.exists() or not any(CACHE.glob(\"year_month=*/*.parquet\")):\n",
    "    raise FileNotFoundError(\n",
    "        \"Wikipedia pageview cache not found. Run \"\n",
    "        \"`python data/fetch_wikipedia.py` from the project root first.\"\n",
    "    )\n",
    "\n",
    "t0 = time.perf_counter()\n",
    "wiki = (\n",
    "    pl.scan_parquet(str(CACHE / \"**/*.parquet\"))\n",
    "    .filter(pl.col(\"project\") == \"en.wikipedia\")\n",
    "    .select([\"article\", \"timestamp\", \"views\"])\n",
    "    .sort([\"article\", \"timestamp\"])\n",
    "    .collect()\n",
    ")\n",
    "query_ms = (time.perf_counter() - t0) * 1000\n",
    "\n",
    "df = wiki.to_pandas()\n",
    "df[\"timestamp\"] = pd.to_datetime(df[\"timestamp\"])\n",
    "\n",
    "n_articles = df[\"article\"].nunique()\n",
    "n_days = df[\"timestamp\"].nunique()\n",
    "print(f\"loaded {len(df):,} rows in {query_ms:.0f} ms (lazy scan + predicate pushdown)\")\n",
    "print(f\"  {n_articles} articles x {n_days} days, {df['timestamp'].min().date()} to {df['timestamp'].max().date()}\")\n",
    "print(f\"\\nsample rows:\")\n",
